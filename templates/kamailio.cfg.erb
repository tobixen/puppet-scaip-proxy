#!KAMAILIO
# SCAIP SIP Proxy — managed by Puppet, do not edit manually.
#
# Forwards SIP/SIPS traffic from internal RFC1918 alarm devices to the
# upstream SCAIP server over TLS.
#
# Health:    http://<host>:<%= @http_port %>/health
# Readiness: http://<host>:<%= @http_port %>/ready
# Metrics:   http://<host>:<%= @http_port %>/metrics

####### Global Parameters #######

debug=<%= @debug_level %>
log_stderror=no
log_facility=<%= @log_facility %>
log_prefix="{$mt $hdr(CSeq) $ci} "

# Worker processes — 2 per CPU core is a typical starting point
children=<%= @children %>

# Internal interface (alarm device clients)
listen=udp:<%= @listen_address %>:<%= @listen_port %>
listen=tcp:<%= @listen_address %>:<%= @listen_port %>
<% if @tls_enabled -%>
listen=tls:<%= @listen_address %>:<%= @listen_tls_port %>
<% end -%>
<% if @public_ip != @listen_address && @listen_address != '0.0.0.0' -%>

# External interface — required so Kamailio has a socket bound to the public
# IP and can use it as the source when establishing outgoing TLS connections
# to the upstream SCAIP server.
listen=udp:<%= @public_ip %>:<%= @listen_port %>
listen=tcp:<%= @public_ip %>:<%= @listen_port %>
<% if @tls_enabled -%>
listen=tls:<%= @public_ip %>:<%= @listen_tls_port %>
<% end -%>
<% end -%>

# HTTP port for health/readiness probes and Prometheus metrics
listen=tcp:<%= @listen_address %>:<%= @http_port %>

# Public IP alias used to rewrite Contact and Via headers for NAT
alias=<%= @public_ip %>
<% if @tls_enabled -%>
enable_tls=1
<% end -%>

####### Modules Section #######

loadmodule "tm.so"
loadmodule "sl.so"
loadmodule "rr.so"
loadmodule "pv.so"
loadmodule "maxfwd.so"
loadmodule "textops.so"
loadmodule "siputils.so"
loadmodule "xlog.so"
loadmodule "sanity.so"
loadmodule "nathelper.so"
<% if @tls_enabled -%>
loadmodule "tls.so"
<% end -%>
loadmodule "xhttp.so"
<% if @metrics_enabled -%>
# xhttp_prom.so is in the base kamailio package
loadmodule "xhttp_prom.so"
<% end -%>

####### Module Parameters #######

<% if @tls_enabled -%>
modparam("tls", "config", "/etc/kamailio/tls.cfg")
<% end -%>

# Full loose-routing ensures in-dialog requests (BYE, re-INVITE, etc.)
# are routed correctly through the proxy.
modparam("rr", "enable_full_lr", 1)

####### Routing Logic #######

request_route {
    route(REQINIT);

    t_check_trans();

    # In-dialog requests (ACK, BYE, re-INVITE, etc.)
    if (has_totag()) {
        route(WITHINDLG);
        exit;
    }

    # Stay in the signalling path for the duration of the dialog
    if (is_method("INVITE|SUBSCRIBE")) {
        record_route();
    }

    # Detect NAT and rewrite the Contact header with our public alias so
    # that the upstream can reach the client through us on the return path.
    if (nat_uac_test("19")) {
        if (is_first_hop()) {
            set_contact_alias();
        }
        setflag(6);
    }

    # Requests addressed to us come from alarm devices and must be forwarded
    # upstream.  Requests addressed to someone else (e.g. the alarm device's
    # URI) come from the upstream and must be relayed directly to the device
    # — not looped back to the upstream.
    if (uri==myself) {
        route(UPSTREAM);
    } else {
        route(RELAY);
    }
}

# Initial request sanity checks
route[REQINIT] {
    if (!sanity_check("1511", "7")) {
        xlog("L_WARN", "Malformed SIP message from $si:$sp — dropping\n");
        exit;
    }

    if (!mf_process_maxfwd_header("10")) {
        sl_send_reply("483", "Too Many Hops");
        exit;
    }

    # Respond to OPTIONS keepalives addressed to us (e.g. from the upstream)
    if (is_method("OPTIONS") && uri==myself) {
        sl_send_reply("200", "Keepalive");
        exit;
    }
}

# In-dialog request handling (loose routing)
route[WITHINDLG] {
    if (loose_route()) {
        route(RELAY);
    } else {
        if (is_method("ACK")) {
            if (t_check_trans()) {
                route(RELAY);
            } else {
                exit;
            }
        }
        sl_send_reply("404", "Not Here");
    }
    exit;
}

# Route to the upstream SCAIP server
route[UPSTREAM] {
    $du = "<%= @upstream_scheme %>:<%= @upstream_host %>:<%= @upstream_port %>;transport=tls";

    # Rewrite the Request-URI domain to the upstream host.  The upstream
    # rejects requests still addressed to the proxy hostname (408 Timeout).
    # Use $rd (domain of R-URI) rather than assigning a full string to $ru —
    # Kamailio does not expand PVs inside string literals assigned to $ru.
    $rd = "<%= @upstream_host %>";

    # Rewrite the To header domain to match — the upstream also inspects it.
    $var(to_user) = $tU;
    remove_hf("To");
    append_hf("To: <sip:$var(to_user)@<%= @upstream_host %>>\r\n");

    xlog("L_INFO", "Routing $rm from $si to $du (R-URI: $ru) — Call-ID: $ci\n");
    route(RELAY);
}

# Generic stateful relay
route[RELAY] {
    if (!t_relay()) {
        sl_reply_error();
    }
    exit;
}

####### HTTP: health, readiness, metrics #######

event_route[xhttp:request] {
    set_reply_close();
    set_reply_no_connect();

    if ($hu =~ "^/health") {
        xhttp_reply("200", "OK", "text/plain", "OK\n");
        exit;
    }

    if ($hu =~ "^/ready") {
        xhttp_reply("200", "OK", "text/plain", "OK\n");
        exit;
    }

<% if @metrics_enabled -%>
    if ($hu =~ "^/metrics") {
        prom_dispatch();
        exit;
    }

<% end -%>
    xhttp_reply("404", "Not Found", "text/plain", "Not Found\n");
}
